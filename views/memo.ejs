<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/css/memo.css" />
  </head>
  <body class="memo-page">
    <div class="page-shell">
      <header class="page-header">
        <div class="header-inner">
          <h1><%= title %></h1>
          <p class="subtitle">テキストを入力してメモを作成できます。</p>
        </div>
        <nav class="header-nav">
          <a href="/" class="nav-link">ホーム</a>
          <a href="/klee-one" class="nav-link">Klee One</a>
          <a href="/contact" class="nav-link">お問い合わせ</a>
          <a
            href="#"
            class="nav-link"
            onclick="
              window.location.reload();
              return false;
            "
            >再読み込み</a
          >
        </nav>
      </header>

      <main class="page-main">
        <section class="content">
          <div class="memo-input-section">
            <label for="memoInput" class="input-label">メモを入力:</label>
            <textarea
              id="memoInput"
              class="memo-textarea"
              placeholder="ここにメモを入力してください..."
              rows="6"
            ></textarea>
            <button
              id="createButton"
              class="button create-button"
              type="button"
            >
              メモを作成
            </button>
          </div>

          <div id="memoContainer" class="memo-container"></div>
        </section>
      </main>
    </div>

    <script src="/js/app.js"></script>
    <script src="/js/memo.js"></script>
  </body>
</html>
